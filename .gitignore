# -----------------------------------------------------------------------------
# Data Masking System v2.3.0 - Специфічні файли
# -----------------------------------------------------------------------------

# Вхідні файли (опціонально)
input.txt
input_*.txt

# Вихідні замасковані файли
output_*.txt
*_masked.txt
*_masked_*.txt

# Зашифровані файли
*.enc
*_masked.enc

# Mapping файли (містять sensitive дані!)
masking_map_*.json
mapping_*.json
*_mapping.json
*.map.json

# Зашифровані mapping файли
masking_map_*.json.enc
mapping_*.enc

# Звіти маскування
masking_report_*.txt
*_report.txt
*_report_*.txt

# Відновлені файли
*_restored.txt
*_unmasked.txt
input_recovery_*.txt

# Логи маскування
masking_*.log
data_masking_*.log
*.masking.log

# Конфігурація (генерується --init-config, містить паролі)
config.yaml
config.yml
!config/config_example.yaml

# Re-mask chain файли
*_chain.json
remask_chain_*.json

# Тимчасові файли
*.tmp
*.temp
*.bak
*.backup

# Тестові файли (опціонально)
test_input*.txt
test_output*.txt
test_*.enc

